{
  "name": "league-calculator",
  "version": "0.1.0",
  "description": "League rating algorithm (Elo-based) for use in an Express app",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "league",
    "rating",
    "elo",
    "ranking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
